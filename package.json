{
  "name": "reurci",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@trpc/server": "^11.16.0",
      "better-auth": "1.6.22",
      "lucide-react": "^1.21.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "sonner": "^2.0.7",
      "tailwindcss": "^4.3.1",
      "@trpc/client": "^11.16.0",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev -F web",
    "dev:server": "turbo run dev -F server",
    "db:push": "turbo run db:push -F @reurci/db",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "db:studio": "turbo run db:studio -F @reurci/db",
    "db:generate": "turbo run db:generate -F @reurci/db",
    "db:migrate": "turbo run db:migrate -F @reurci/db",
    "db:start": "turbo run db:start -F @reurci/db",
    "db:watch": "turbo run db:watch -F @reurci/db",
    "db:stop": "turbo run db:stop -F @reurci/db",
    "db:down": "turbo run db:down -F @reurci/db"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.7",
    "@ai-sdk/react": "^4.0.15",
    "@mastra/ai-sdk": "^1.6.1",
    "@mastra/core": "^1.49.0",
    "@mastra/duckdb": "^1.5.0",
    "@mastra/libsql": "^1.15.0",
    "@mastra/loggers": "^1.2.0",
    "@mastra/memory": "^1.22.1",
    "@mastra/observability": "^1.15.2",
    "@reurci/env": "workspace:*",
    "ai": "^7.0.14",
    "dotenv": "catalog:",
    "mastra": "^1.18.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@reurci/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.10.2",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.14"
}
